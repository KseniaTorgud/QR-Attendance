openapi: 3.0.3
info:
  title: Student Event QR Backend API
  version: 1.0.0
  description: Backend API for student registration by QR and selfie confirmation.
paths:
  /api/v1/auth/me/:
    get:
      operationId: api_v1_auth_me_retrieve
      tags:
      - Auth
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SafeUser'
          description: ''
  /api/v1/auth/register/:
    post:
      operationId: api_v1_auth_register_create
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/StudentRegistrationRequest'
            examples:
              StudentRegistrationRequest:
                value:
                  username: student1
                  password: strongpass123
                  first_name: Ivan
                  last_name: Petrov
                summary: Student registration request
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/StudentRegistrationRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/StudentRegistrationRequest'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SafeUser'
          description: ''
  /api/v1/auth/token/:
    post:
      operationId: api_v1_auth_token_create
      description: |-
        Takes a set of user credentials and returns an access and refresh JSON web
        token pair to prove the authentication of those credentials.
      tags:
      - api
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TokenObtainPairRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TokenObtainPairRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TokenObtainPairRequest'
        required: true
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TokenObtainPair'
          description: ''
  /api/v1/auth/token/refresh/:
    post:
      operationId: api_v1_auth_token_refresh_create
      description: |-
        Takes a refresh type JSON web token and returns an access type JSON web
        token if the refresh token is valid.
      tags:
      - api
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TokenRefreshRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TokenRefreshRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TokenRefreshRequest'
        required: true
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TokenRefresh'
          description: ''
  /api/v1/events/:
    get:
      operationId: api_v1_events_list
      parameters:
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: page_size
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      tags:
      - Events
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedEventList'
          description: ''
    post:
      operationId: api_v1_events_create
      tags:
      - Events
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/EventCreateUpdateRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/EventCreateUpdateRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/EventCreateUpdateRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Event'
          description: ''
  /api/v1/events/{id}/:
    get:
      operationId: api_v1_events_retrieve
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this event.
        required: true
      tags:
      - Events
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Event'
          description: ''
    put:
      operationId: api_v1_events_update
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this event.
        required: true
      tags:
      - api
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/EventCreateUpdateRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/EventCreateUpdateRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/EventCreateUpdateRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/EventCreateUpdate'
          description: ''
    patch:
      operationId: api_v1_events_partial_update
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this event.
        required: true
      tags:
      - Events
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedEventCreateUpdateRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedEventCreateUpdateRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedEventCreateUpdateRequest'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Event'
          description: ''
    delete:
      operationId: api_v1_events_destroy
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this event.
        required: true
      tags:
      - Events
      security:
      - jwtAuth: []
      responses:
        '204':
          description: Deleted
  /api/v1/events/{id}/regenerate-qr/:
    post:
      operationId: api_v1_events_regenerate_qr_create
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this event.
        required: true
      tags:
      - Events
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/RegenerateQR'
          description: ''
  /api/v1/events/{id}/register-by-qr/:
    post:
      operationId: api_v1_events_register_by_qr_create
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this event.
        required: true
      tags:
      - Events
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/RegisterByQRRequest'
            examples:
              RegisterByQR:
                value:
                  qr_token: sample_qr_token
                summary: Register by QR
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/RegisterByQRRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/RegisterByQRRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Registration'
          description: ''
        '400':
          description: Validation error.
        '409':
          description: Conflict.
  /api/v1/exports/event/{id}/registrations.csv:
    get:
      operationId: api_v1_exports_event_registrations.csv_retrieve
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        required: true
      tags:
      - Exports
      security:
      - jwtAuth: []
      responses:
        '200':
          description: CSV file
  /api/v1/exports/rating.csv:
    get:
      operationId: api_v1_exports_rating.csv_retrieve
      tags:
      - Exports
      security:
      - jwtAuth: []
      responses:
        '200':
          description: CSV file
  /api/v1/registrations/:
    get:
      operationId: api_v1_registrations_list
      parameters:
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: page_size
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      tags:
      - Registrations
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedRegistrationList'
          description: ''
  /api/v1/registrations/{id}/:
    get:
      operationId: api_v1_registrations_retrieve
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this registration.
        required: true
      tags:
      - Registrations
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Registration'
          description: ''
  /api/v1/registrations/{id}/confirm/:
    patch:
      operationId: api_v1_registrations_confirm_partial_update
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this registration.
        required: true
      tags:
      - Registrations
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedConfirmRegistrationRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedConfirmRegistrationRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedConfirmRegistrationRequest'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Registration'
          description: ''
  /api/v1/registrations/{id}/mark-attendance/:
    patch:
      operationId: api_v1_registrations_mark_attendance_partial_update
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this registration.
        required: true
      tags:
      - Registrations
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Registration'
          description: ''
  /api/v1/registrations/{id}/upload-selfie/:
    patch:
      operationId: api_v1_registrations_upload_selfie_partial_update
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this registration.
        required: true
      tags:
      - Registrations
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedSelfieUploadRequest'
            examples:
              SelfieUpload:
                value:
                  selfie: <binary image>
                summary: Multipart form-data example
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedSelfieUploadRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedSelfieUploadRequest'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Registration'
          description: ''
        '400':
          description: Invalid image or file too large.
  /api/v1/stats/events/{id}/:
    get:
      operationId: api_v1_stats_events_retrieve
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        required: true
      tags:
      - Statistics
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                type: object
                properties:
                  total_registrations:
                    type: integer
                  total_confirmed:
                    type: integer
                  total_rejected:
                    type: integer
                  total_pending:
                    type: integer
                  free_slots:
                    type: integer
          description: Event stats
  /api/v1/stats/rating/:
    get:
      operationId: api_v1_stats_rating_list
      tags:
      - Statistics
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/Rating'
          description: ''
  /api/v1/users/:
    get:
      operationId: api_v1_users_list
      parameters:
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: page_size
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      tags:
      - Users
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedSafeUserList'
          description: ''
  /api/v1/users/{id}/:
    get:
      operationId: api_v1_users_retrieve
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this user.
        required: true
      tags:
      - Users
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SafeUser'
          description: ''
    put:
      operationId: api_v1_users_update
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this user.
        required: true
      tags:
      - api
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/SafeUserRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/SafeUserRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/SafeUserRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SafeUser'
          description: ''
    patch:
      operationId: api_v1_users_partial_update
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this user.
        required: true
      tags:
      - Users
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedAdminUserUpdateRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedAdminUserUpdateRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedAdminUserUpdateRequest'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SafeUser'
          description: ''
  /api/v1/users/teachers/:
    post:
      operationId: api_v1_users_teachers_create
      tags:
      - Users
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TeacherCreateRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TeacherCreateRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TeacherCreateRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SafeUser'
          description: ''
        '403':
          description: Only admin can create teacher accounts.
components:
  schemas:
    ConfirmRegistrationAttendanceStatusEnum:
      enum:
      - confirmed
      - rejected
      type: string
      description: |-
        * `confirmed` - confirmed
        * `rejected` - rejected
    Event:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        title:
          type: string
          maxLength: 255
        description:
          type: string
        location:
          type: string
          maxLength: 255
        start_at:
          type: string
          format: date-time
        registration_deadline:
          type: string
          format: date-time
        max_participants:
          type: integer
          maximum: 9223372036854775807
          minimum: 0
          format: int64
        status:
          $ref: '#/components/schemas/StatusEnum'
        qr_token:
          type: string
          readOnly: true
        created_by:
          allOf:
          - $ref: '#/components/schemas/Owner'
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - created_at
      - created_by
      - id
      - location
      - max_participants
      - qr_token
      - registration_deadline
      - start_at
      - title
      - updated_at
    EventCreateUpdate:
      type: object
      properties:
        title:
          type: string
          maxLength: 255
        description:
          type: string
        location:
          type: string
          maxLength: 255
        start_at:
          type: string
          format: date-time
        registration_deadline:
          type: string
          format: date-time
        max_participants:
          type: integer
          maximum: 9223372036854775807
          minimum: 0
          format: int64
        status:
          $ref: '#/components/schemas/StatusEnum'
      required:
      - location
      - max_participants
      - registration_deadline
      - start_at
      - title
    EventCreateUpdateRequest:
      type: object
      properties:
        title:
          type: string
          minLength: 1
          maxLength: 255
        description:
          type: string
        location:
          type: string
          minLength: 1
          maxLength: 255
        start_at:
          type: string
          format: date-time
        registration_deadline:
          type: string
          format: date-time
        max_participants:
          type: integer
          maximum: 9223372036854775807
          minimum: 0
          format: int64
        status:
          $ref: '#/components/schemas/StatusEnum'
      required:
      - location
      - max_participants
      - registration_deadline
      - start_at
      - title
    Owner:
      type: object
      properties:
        id:
          type: integer
        username:
          type: string
        role:
          type: string
      required:
      - id
      - role
      - username
    PaginatedEventList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=4
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=2
        results:
          type: array
          items:
            $ref: '#/components/schemas/Event'
    PaginatedRegistrationList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=4
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=2
        results:
          type: array
          items:
            $ref: '#/components/schemas/Registration'
    PaginatedSafeUserList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=4
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=2
        results:
          type: array
          items:
            $ref: '#/components/schemas/SafeUser'
    PatchedAdminUserUpdateRequest:
      type: object
      properties:
        first_name:
          type: string
          maxLength: 150
        last_name:
          type: string
          maxLength: 150
        role:
          $ref: '#/components/schemas/RoleEnum'
        is_active:
          type: boolean
          title: Active
          description: Designates whether this user should be treated as active. Unselect
            this instead of deleting accounts.
    PatchedConfirmRegistrationRequest:
      type: object
      properties:
        attendance_status:
          $ref: '#/components/schemas/ConfirmRegistrationAttendanceStatusEnum'
        confirmation_comment:
          type: string
          maxLength: 255
    PatchedEventCreateUpdateRequest:
      type: object
      properties:
        title:
          type: string
          minLength: 1
          maxLength: 255
        description:
          type: string
        location:
          type: string
          minLength: 1
          maxLength: 255
        start_at:
          type: string
          format: date-time
        registration_deadline:
          type: string
          format: date-time
        max_participants:
          type: integer
          maximum: 9223372036854775807
          minimum: 0
          format: int64
        status:
          $ref: '#/components/schemas/StatusEnum'
    PatchedSelfieUploadRequest:
      type: object
      properties:
        selfie:
          type: string
          format: binary
    Rating:
      type: object
      properties:
        student_id:
          type: integer
        username:
          type: string
        first_name:
          type: string
        last_name:
          type: string
        confirmed_visits:
          type: integer
      required:
      - confirmed_visits
      - first_name
      - last_name
      - student_id
      - username
    RegenerateQR:
      type: object
      properties:
        qr_token:
          type: string
          readOnly: true
      required:
      - qr_token
    RegisterByQRRequest:
      type: object
      properties:
        qr_token:
          type: string
          minLength: 1
          maxLength: 64
      required:
      - qr_token
    Registration:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        student:
          type: integer
          readOnly: true
        student_username:
          type: string
          readOnly: true
        event:
          type: integer
          readOnly: true
        event_title:
          type: string
          readOnly: true
        registered_at:
          type: string
          format: date-time
          readOnly: true
        attendance_marked_by_student:
          type: boolean
          readOnly: true
        attendance_marked_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        selfie:
          type: string
          format: uri
          readOnly: true
          nullable: true
        selfie_uploaded_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        attendance_status:
          allOf:
          - $ref: '#/components/schemas/RegistrationAttendanceStatusEnum'
          readOnly: true
        confirmed_by:
          type: integer
          readOnly: true
          nullable: true
        confirmed_by_username:
          type: string
          readOnly: true
        confirmed_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        confirmation_comment:
          type: string
          readOnly: true
      required:
      - attendance_marked_at
      - attendance_marked_by_student
      - attendance_status
      - confirmation_comment
      - confirmed_at
      - confirmed_by
      - confirmed_by_username
      - event
      - event_title
      - id
      - registered_at
      - selfie
      - selfie_uploaded_at
      - student
      - student_username
    RegistrationAttendanceStatusEnum:
      enum:
      - pending
      - confirmed
      - rejected
      type: string
      description: |-
        * `pending` - Pending
        * `confirmed` - Confirmed
        * `rejected` - Rejected
    RoleEnum:
      enum:
      - admin
      - teacher
      - student
